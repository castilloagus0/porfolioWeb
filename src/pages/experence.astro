---
import BaseLayout from '../layouts/BaseLayout.astro';
import Layout from '../layouts/Layout.astro';
import ExperienceSection from '../components/ExperienceSection.astro';
import Footer from '../components/Footer.astro';
import { CV_PDF_PATH } from '../config/contact';
---

<BaseLayout>
	<header class="fixed top-0 left-0 right-0 z-50 w-full px-6 sm:px-10 py-5 bg-[#111827]/95 backdrop-blur-sm border-b border-slate-800/50">
		<nav class="max-w-6xl mx-auto flex items-center justify-between">
			<a href="/" class="text-lg sm:text-xl font-bold text-white tracking-tight font-heading">
				AGUSDESIGN
			</a>
			<div class="flex items-center gap-4 sm:gap-6">
				<a href="/#about-me" class="text-sm text-slate-300 hover:text-white transition-colors">
					SOBRE MI
				</a>
				<a href="/#experience" class="text-sm text-white font-medium">
					EXPERIENCIA
				</a>
				<a href="/#projects" class="text-sm text-slate-300 hover:text-white transition-colors">
					PROYECTOS
				</a>
				<a href={CV_PDF_PATH} download target="_blank" rel="noopener noreferrer" class="text-sm text-slate-300 hover:text-white transition-colors hidden sm:inline-flex">
					DESCARGAR CV
				</a>
				<a href="/#contact" class="px-5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white text-sm font-semibold rounded-lg transition-colors">
					CONTACTAME
				</a>
			</div>
		</nav>
	</header>

	<div class="pt-20">
		<Layout>
			<ExperienceSection />
			<Footer />
		</Layout>
	</div>
</BaseLayout>
